// This is a comment
for (i: int = 0; i < n; i++) {
        print("*" * i); // inline comment
}

i: int = 0;
while (i < 10) {
        if (i % 2 == 0) {
                print(i);
        } else {
                print(0);
        }
}

fn pow(a: int, n: int): int {
        result: int = a;
        for (i: int = 0; i <= n; i++) {
                result *= a;
        }
        return result;
}

